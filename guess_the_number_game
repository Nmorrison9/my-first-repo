import random
import art

random_number = list(range(1, 101))
chosen_number = random.choice(random_number)

def easy_mode():
    attempts = 10
    win = False
    while attempts > 0:
        print(f" You have {attempts} attempts remaining to guess the number.")
        try:
            user_guess = int(input("Make a guess:  "))
        except ValueError:
            print("Invalid input. Please enter a number.")
            continue
        if user_guess < chosen_number:
            attempts -= 1
            print("Too low.")
        elif user_guess > chosen_number:
            attempts -= 1
            print("Too high.")
        else:
            print("You got it! Congratulations!")
            win = True
            break
    if not win:
        print("You lost! Maybe next time!")
        print(f"The number was: {chosen_number}")

