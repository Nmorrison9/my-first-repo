from turtle import Screen, Turtle
import time
from scoreboard import Scoreboard
from paddle import Paddle
from ball import Ball

screen = Screen()
screen.setup(width=800, height=600)
screen.bgcolor("black")
screen.title("Pong")
screen.tracer(0)
screen.update()

right_paddle = Paddle((350,0))
left_paddle = Paddle((-350, 0))
ball = Ball((0,0))

screen.listen()
scoreboard = Scoreboard()

screen.onkey(right_paddle.paddle_up, "Up")
screen.onkey(right_paddle.paddle_down, "Down")
screen.onkey(left_paddle.paddle_up, "w")
screen.onkey(left_paddle.paddle_down, "s")

game_is_on = True
while game_is_on:
    time.sleep(ball.move_speed)
    screen.update()
    ball.move()
    if ball.ycor() > 287 or ball.ycor() < -287:
        ball.bounce()

    if ball.xcor() > 330 and ball.distance(right_paddle) < 50 or ball.xcor() < -330 and ball.distance(left_paddle) < 50:
        ball.hit_back()

    if ball.xcor() > 390:
        scoreboard.increase_left_score()
        scoreboard.update_score()
        ball.restart()

    if ball.xcor() < -390:
        scoreboard.increase_right_score()
        scoreboard.update_score()
        ball.restart()


screen.exitonclick()
