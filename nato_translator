importpandas

nato_data = pandas.read_csv("nato_phonetic_alphabet.csv")

nato_dict = {row.letter:row.code for (index, row) in nato_data.iterrows()}

keep_going = True
while keep_going:
    word = input("Enter a word: ").upper()

    try:
        phonetic_alphabet = [nato_dict[letter] for letter in word]
    except KeyError:
        print("Sorry, only letters in the alphabet are allowed")
    else:
        print(phonetic_alphabet)

    another_word = input("Would you like to do another word? yes or no: ")
    if another_word == "yes":
        keep_going = True
    else:
        keep_going = False



